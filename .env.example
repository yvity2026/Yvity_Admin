# =============================================================================
# YVITY Admin — production (Vercel) environment variables
# Copy to Vercel Project → Settings → Environment Variables
# =============================================================================

# --- Required: Supabase (same project as Yvity_Users) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# --- Required: public URLs ---
NEXT_PUBLIC_BASE_URL=https://admin.yourdomain.com
YVITY_GOLD_BASE_URL=https://app.yourdomain.com
NEXT_PUBLIC_YVITY_GOLD_BASE_URL=https://app.yourdomain.com

# --- Required: admin login OTP (WhatsApp) — same gateway as Yvity_Users ---
WHATSAPP_API_URL=https://your-whatsapp-gateway.example/send
WHATSAPP_ACCESS_TOKEN=your_whatsapp_bearer_token
# Optional message template ({code} placeholder supported):
# WHATSAPP_OTP_MESSAGE=Your YVITY verification code is {code}. Valid for 5 minutes.
#
# Do NOT set WHATSAPP_OTP_TEMPLATE_NAME for the Yvity_Users gateway.
# Only for direct Meta Graph URLs (graph.facebook.com/.../messages):
# WHATSAPP_OTP_DELIVERY_MODE=meta
# WHATSAPP_OTP_TEMPLATE_NAME=your_otp_template_name
# WHATSAPP_OTP_TEMPLATE_LANGUAGE=en

# --- Production safety (set on Vercel) ---
YVITY_ADMIN_DEV_AUTH=false
NODE_ENV=production

# Do NOT set on Vercel (local dev only):
# YVITY_USE_LOCAL_APPROVALS=true
# YVITY_FORCE_LOCAL_DATA=true
# YVITY_ADMIN_DEV_PHONE / YVITY_ADMIN_DEV_OTP

# --- Optional: uploads (S3) ---
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=

# --- Optional: payments (admin payment links) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Optional: email in Settings module ---
# EMAIL_USER=
# EMAIL_PASS=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=
