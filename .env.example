# =============================================================================
# YVITY Admin — Vercel / production environment variables
# Copy each line to: Vercel → Project → Settings → Environment Variables
# Validate locally: npm run verify:env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Supabase (Yvity_Dev)
# Project ref: akwvvhntxbhjyixaxhpv
# Dashboard: https://supabase.com/dashboard/project/akwvvhntxbhjyixaxhpv/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://akwvvhntxbhjyixaxhpv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# REQUIRED — Public URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://admin.yourdomain.com
YVITY_GOLD_BASE_URL=https://app.yourdomain.com
NEXT_PUBLIC_YVITY_GOLD_BASE_URL=https://app.yourdomain.com

# -----------------------------------------------------------------------------
# REQUIRED — Admin login OTP (WhatsApp)
# Use the same gateway as Yvity_Users (recommended):
#   WHATSAPP_API_URL + WHATSAPP_ACCESS_TOKEN
# Or Meta Cloud API (builds URL from phone number ID):
#   WHATSAPP_PHONE_NUMBER_ID + WHATSAPP_ACCESS_TOKEN
#   WHATSAPP_OTP_DELIVERY_MODE=meta
#   WHATSAPP_OTP_TEMPLATE_NAME=your_approved_template
# -----------------------------------------------------------------------------
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=

# Optional — Meta Graph (only if NOT using Yvity_Users gateway URL above)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_GRAPH_API_VERSION=v21.0
# WHATSAPP_OTP_DELIVERY_MODE=meta
# WHATSAPP_OTP_TEMPLATE_NAME=
# WHATSAPP_OTP_TEMPLATE_LANGUAGE=en

# Optional — plain-text OTP for gateway mode ({code} placeholder)
# WHATSAPP_OTP_MESSAGE=Your YVITY verification code is {code}. Valid for 5 minutes.

# Fallback token name (Yvity_Users uses WHATSAPP_API_TOKEN — same value works here)
# WHATSAPP_API_TOKEN=

# Not read by Admin code (display / documentation only)
# WHATSAPP_BUSINESS_NUMBER=

# -----------------------------------------------------------------------------
# REQUIRED — Production safety (Vercel sets NODE_ENV=production automatically)
# Do NOT set NODE_ENV manually on Vercel.
# -----------------------------------------------------------------------------
YVITY_ADMIN_DEV_AUTH=false

# -----------------------------------------------------------------------------
# RECOMMENDED — S3 uploads (testimonials, platform review media)
# -----------------------------------------------------------------------------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# -----------------------------------------------------------------------------
# FIRST-TIME ADMIN — seed super admin in Supabase (run once locally)
# npm run bootstrap:admin
# Default phone: +919014143132 (Krishna Mohan Noti)
# Or: YVITY_BOOTSTRAP_ADMIN_PHONE=9014143132 YVITY_BOOTSTRAP_ADMIN_NAME="Your Name"
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# LOCAL DEV ONLY — never set on Vercel production
# -----------------------------------------------------------------------------
# YVITY_USE_LOCAL_APPROVALS=true
# YVITY_FORCE_LOCAL_DATA=true
# YVITY_ADMIN_DEV_PHONE=9014143132
# YVITY_ADMIN_DEV_OTP=123456
# YVITY_ALLOW_DEMO_OTP=true

# -----------------------------------------------------------------------------
# NOT USED BY YVITY_ADMIN (keep on Vercel only if shared with Yvity_Users)
# Admin auth uses admin_session cookies, not JWT.
# Email SMTP is stored in Settings UI (database), not EMAIL_USER/EMAIL_PASS env.
# Razorpay checkout lives in Yvity_Users — Admin only displays payment records.
# -----------------------------------------------------------------------------
# JWT_SECRET_KEY=
# CODE_SECRET=
# EMAIL_USER=
# EMAIL_PASS=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_WEBHOOK_SECRET=
